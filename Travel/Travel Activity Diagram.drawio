<mxfile host="app.diagrams.net" pages="3">
  <diagram name="Page-1" id="l3sP-NUPJ66zlXH9bMyD">
    <mxGraphModel dx="1935" dy="1128" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\nclass Customer {\n  -customerID : int\n  -name : string\n  -address : string\n  -contact : string\n  +provideRequirements()\n  +acceptItinerary()\n  +makePayment()\n}\n\nclass SalesConsultant {\n  -consultantID : int\n  -name : string\n  +matchRequirements()\n  +suggestAlternatives()\n  +makeBookings()\n  +organizeExtras()\n}\n\nclass Itinerary {\n  -itineraryID : int\n  -details : string\n  +generatePrintout()\n}\n\nclass Payment {\n  -paymentID : int\n  -amount : double\n  -method : string\n  +processPayment()\n}\n\nclass CreditCardPayment extends Payment {\n  -commissionRate : double\n  +applyCommission()\n}\n\nclass Booking {\n  -bookingID : int\n  -type : string\n  +confirmBooking()\n}\n\nclass Flight {\n  -flightNo : string\n  -departure : string\n  -arrival : string\n}\n\nclass Hotel {\n  -hotelName : string\n  -location : string\n}\n\nclass Insurance {\n  -policyNo : string\n  -coverage : string\n}\n\nclass CarHire {\n  -carID : string\n  -type : string\n}\n\nCustomer \&quot;1\&quot; -- \&quot;1\&quot; SalesConsultant : registeredWith\nSalesConsultant \&quot;1\&quot; -- \&quot;many\&quot; Booking : manages\nBooking \&quot;1\&quot; o-- \&quot;1\&quot; Flight : aggregation\nBooking \&quot;1\&quot; o-- \&quot;1\&quot; Hotel : aggregation\nItinerary \&quot;1\&quot; *-- \&quot;many\&quot; Booking : composition\nCustomer \&quot;1\&quot; -- \&quot;many\&quot; Payment : makes\nPayment &lt;|-- CreditCardPayment\n@enduml\n&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="k2pja6fUOrffSZINQvOB-1">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="715" width="714" x="20" y="20" as="geometry" />
          </mxCell>
        </UserObject>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="o9gg_YOGDZDmh5b2XXSn" name="Page-2">
    <mxGraphModel dx="774" dy="451" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\nleft to right direction\nactor Customer\nactor SalesConsultant\n\nrectangle \&quot;Booking System\&quot; {\n  Customer --&gt; (Provide Requirements)\n  SalesConsultant --&gt; (Match Requirements)\n  SalesConsultant --&gt; (Suggest Alternatives)\n  SalesConsultant --&gt; (Make Bookings)\n  SalesConsultant --&gt; (Organize Insurance &amp; Car Hire)\n  (Provide Requirements) --&gt; (Generate Itinerary)\n  Customer --&gt; (Accept Itinerary)\n}\n\nrectangle \&quot;Payment System\&quot; {\n  Customer --&gt; (Pay Full Invoice)\n  Customer --&gt; (Pay Deposit)\n  Customer --&gt; (Pay by Credit Card)\n  (Pay by Credit Card) --&gt; (Add Commission)\n  (Pay Full Invoice) --&gt; (Generate Receipt)\n}\n@enduml\n&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="eJb6yLB-9pUEuMRnP9yM-1">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="701" width="628" x="20" y="20" as="geometry" />
          </mxCell>
        </UserObject>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="ztDDbySnSePTIBIkaoeU" name="Page-3">
    <mxGraphModel dx="774" dy="451" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\nstart\n:Customer provides requirements;\n:Sales Consultant matches requirements;\nif (Exact match available?) then (Yes)\n  :Make Bookings;\nelse (No)\n  :Suggest Alternatives;\nendif\n:Generate Itinerary;\n:Customer accepts itinerary?;\nif (Accepted?) then (Yes)\n  :Proceed to Payment;\n  if (Full Payment?) then (Yes)\n    :Process Payment;\n    :Generate Receipt;\n  else (Deposit)\n    :Process Deposit;\n    :Provisional Booking;\n  endif\nelse (No)\n  :Cancel Request;\nendif\nstop\n@enduml\n&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="XkqCZZzFEAwY8U_8bfxv-1">
